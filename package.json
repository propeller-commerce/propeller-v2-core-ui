{
  "name": "propeller-v2-core-ui",
  "version": "0.2.3",
  "description": "Framework-agnostic core for Propeller Commerce UI packages — pure TS types, normalizers, SDK service factory, and the Result<T> contract. Consumed by propeller-v2-vue-ui and propeller-v2-react-ui.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\""
  },
  "peerDependencies": {
    "propeller-sdk-v2": "*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.7",
    "propeller-sdk-v2": "github:propeller-commerce/propeller-sdk-v2#master",
    "tsup": "^8.3.5",
    "typescript": "~5.9",
    "vitest": "^4.1.7"
  },
  "sideEffects": false
}
